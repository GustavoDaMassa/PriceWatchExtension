{
  "manifest_version": 3,
  "name": "PriceWatch — Monitor de Preços",
  "version": "1.1.0",
  "description": "Acompanhe preços do Mercado Livre e receba alertas quando o produto atingir seu preço-alvo. Um clique para acompanhar.",

  "minimum_chrome_version": "88",

  "permissions": ["storage"],

  "host_permissions": [
    "*://*.mercadolivre.com.br/*",
    "https://pricewatch-api.gustavohdev.com.br/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.mercadolivre.com.br/*"],
      "js": ["content-ml.js"],
      "run_at": "document_idle"
    }
  ]
}
