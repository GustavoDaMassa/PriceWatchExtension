{
  "manifest_version": 3,
  "name": "PriceWatch",
  "version": "1.0.0",
  "description": "Acompanhe preços do Mercado Livre diretamente pelo PriceWatch.",

  "permissions": ["storage"],

  "host_permissions": [
    "*://*.mercadolivre.com.br/*",
    "http://localhost:4200/*",
    "http://localhost:5283/*",
    "https://api.financeapi.com.br/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://*.mercadolivre.com.br/*"],
      "js": ["content-ml.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:4200/*"],
      "js": ["content-spa.js"],
      "run_at": "document_idle"
    }
  ]
}
